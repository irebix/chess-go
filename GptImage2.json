{
  "1": {
    "inputs": {
      "image": "鸡尾酒24_2_看图王.jpg"
    },
    "class_type": "LoadImage",
    "_meta": {
      "title": "GPT Image 2｜风格参考图"
    }
  },
  "2": {
    "inputs": {
      "value": "参考图并学习，画风与参考图保持一致。注意是卡通风格，物件透视要和参考图一致；不要写实，使用柔和且光滑的渐变，不要出现水彩质感。色彩鲜艳明快，左侧有轻微投影，点缀物数量要少而大，细节克制。除整体外轮廓外不要添加内部描边。不要复制参考图中的具体物件或文字。\n\n{{CHESS_GO_ITEMS}}"
    },
    "class_type": "PrimitiveStringMultiline",
    "_meta": {
      "title": "GPT Image 2｜整链提示词"
    }
  },
  "3": {
    "inputs": {
      "value": "[]"
    },
    "class_type": "PrimitiveStringMultiline",
    "_meta": {
      "title": "GPT Image 2｜输出名称"
    }
  },
  "4": {
    "inputs": {
      "aspect_ratio": "3:4",
      "batch_size": "1",
      "request_nonce": 1,
      "vip_channel": true,
      "timeout_seconds": 150,
      "prompt": [
        "2",
        0
      ],
      "images": [
        "1",
        0
      ]
    },
    "class_type": "HolopixGenerateV3",
    "_meta": {
      "title": "GPT Image 2｜整链生成"
    }
  },
  "5": {
    "inputs": {
      "canvas_size": 512,
      "padding": 4,
      "background_threshold": 12,
      "min_object_height_percent": 5,
      "min_box_area_percent": 0.3,
      "max_objects": 12,
      "image": [
        "4",
        0
      ],
      "labels": [
        "3",
        0
      ]
    },
    "class_type": "AutoObjectSheetCrop",
    "_meta": {
      "title": "GPT Image 2｜按顺序裁切"
    }
  },
  "6": {
    "inputs": {
      "model": "BiRefNet_toonout",
      "mask_blur": 1,
      "mask_offset": 1,
      "invert_output": false,
      "refine_foreground": true,
      "background": "Alpha",
      "background_color": "#000000",
      "image": [
        "5",
        0
      ]
    },
    "class_type": "BiRefNetRMBG",
    "_meta": {
      "title": "GPT Image 2｜批量抠图"
    }
  },
  "7": {
    "inputs": {
      "mask": [
        "6",
        1
      ]
    },
    "class_type": "InvertMask",
    "_meta": {
      "title": "GPT Image 2｜前景转 Alpha"
    }
  },
  "8": {
    "inputs": {
      "image": [
        "6",
        0
      ],
      "alpha": [
        "7",
        0
      ]
    },
    "class_type": "JoinImageWithAlpha",
    "_meta": {
      "title": "GPT Image 2｜写入透明通道"
    }
  },
  "9": {
    "inputs": {
      "names": [
        "5",
        1
      ],
      "subfolder": "Holopix/ChessGo/GptImage2/template",
      "collision_policy": "overwrite",
      "png_compress_level": 4,
      "images": [
        "8",
        0
      ]
    },
    "class_type": "SaveNamedImageBatch",
    "_meta": {
      "title": "GPT Image 2｜保存候选"
    }
  }
}
