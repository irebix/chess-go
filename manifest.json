{
  "manifestVersion": 5,
  "id": "com.linkdesks.chess-archive-psd-generator",
  "name": "棋子go",
  "version": "0.3.6",
  "main": "index.html",
  "host": {
    "app": "PS",
    "minVersion": "24.2.0",
    "data": {
      "apiVersion": 2,
      "loadEvent": "use"
    }
  },
  "requiredPermissions": {
    "localFileSystem": "fullAccess",
    "network": {
      "domains": "all"
    },
    "launchProcess": {
      "schemes": [
        "http"
      ],
      "extensions": []
    }
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "chessArchivePsdGenerator",
      "label": {
        "default": "棋子go"
      },
      "minimumSize": {
        "width": 300,
        "height": 420
      },
      "preferredDockedSize": {
        "width": 360,
        "height": 620
      },
      "preferredFloatingSize": {
        "width": 420,
        "height": 720
      },
      "maximumSize": {
        "width": 1200,
        "height": 1200
      }
    }
  ]
}
